# Environment
APP_NAME=FlowForge
ENV=development
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./flowforge.db

# JWT — replace in production
JWT_SECRET=dev-secret-change-me-please-use-32-bytes-min
JWT_EXPIRATION_MINUTES=480

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173

# LLM provider: stub | openai | anthropic
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_DEFAULT_MODEL=stub-1
LLM_OPENAI_MODEL=gpt-4o-mini
LLM_ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Step runtime
STEP_TIMEOUT_SECONDS=60

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@flowforge.example

# Slack
SLACK_WEBHOOK_URL=
